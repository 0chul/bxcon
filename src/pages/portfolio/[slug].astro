---
import ArticleLayout from '@layouts/ArticleLayout.astro';
import { getContentDetail, listContent } from '@lib/queries';
import type { PortfolioDetail } from '@models/content';

export const getStaticPaths = async () => {
  const items = await listContent('portfolio');
  return items.map((item) => ({
    params: { slug: item.slug },
  }));
};

const { slug } = Astro.params;
const item = slug ? ((await getContentDetail('portfolio', slug)) as PortfolioDetail | null) : null;

if (!item || item.kind !== 'portfolio') {
  throw new Error(`Unknown portfolio slug: ${slug}`);
}
---

<ArticleLayout
  item={item}
  breadcrumbs={[
    { label: '홈', href: '/' },
    { label: '포트폴리오', href: '/portfolio/' },
    { label: item.title },
  ]}
  extraMeta={[item.clientName, item.projectPeriod]}
/>
