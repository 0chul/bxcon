---
import Section from '@components/common/Section.astro';
import PageLayout from '@layouts/PageLayout.astro';

const policyHtml = `
  <h2>1. 수집 항목</h2>
  <p>문의 접수 및 뉴스레터 구독 처리를 위해 이름, 이메일, 연락처, 회사명, 문의 내용을 수집할 수 있습니다.</p>
  <h2>2. 이용 목적</h2>
  <p>수집한 정보는 문의 응답, 서비스 안내, 뉴스레터 발송, 운영 개선 목적에 한해 사용합니다.</p>
  <h2>3. 보관 기간</h2>
  <p>관련 법령 또는 내부 운영 기준에 따라 필요한 기간 동안 보관 후 파기합니다.</p>
  <h2>4. 제3자 제공</h2>
  <p>법령에 근거한 경우를 제외하고 정보주체 동의 없이 제3자에게 제공하지 않습니다.</p>
  <h2>5. 문의처</h2>
  <p>개인정보 관련 문의는 contact@bxcon.co.kr 로 접수할 수 있습니다.</p>
`;
---

<PageLayout
  title="개인정보처리방침"
  description="BX컨설팅 사이트 문의 및 뉴스레터 구독 처리와 관련한 개인정보처리방침 초안입니다."
  canonicalPath="/privacy/"
  eyebrow="Privacy"
>
  <Section eyebrow="Policy" title="개인정보처리방침 초안">
    <div class="article-panel">
      <div class="prose" set:html={policyHtml} />
    </div>
  </Section>
</PageLayout>
