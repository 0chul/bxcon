---
import Section from '@components/common/Section.astro';
import ContentGrid from '@components/content/ContentGrid.astro';
import NewsletterSignup from '@components/content/NewsletterSignup.astro';
import ContactCta from '@components/content/ContactCta.astro';
import PageLayout from '@layouts/PageLayout.astro';
import { listContent } from '@lib/queries';

const items = await listContent('insight');
---

<PageLayout
  title="인사이트"
  description="BX컨설팅의 전문가 관점에서 정리한 비즈니스 인사이트 콘텐츠입니다."
  canonicalPath="/insight/"
  eyebrow="Insight"
>
  <Section
    eyebrow="Articles"
    title="리서치와 현장 운영을 연결하는 관점"
    intro="본문은 HTML 기반으로 정적 렌더링되며, 상세 페이지는 client-only 렌더링을 사용하지 않습니다."
  >
    <ContentGrid items={items} />
  </Section>

  <Section eyebrow="Stay Updated" title="새 인사이트가 발행되면 빠르게 받아보세요.">
    <div class="grid-2">
      <NewsletterSignup />
      <ContactCta />
    </div>
  </Section>
</PageLayout>
