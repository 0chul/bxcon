---
import Section from '@components/common/Section.astro';
import ServiceCard from '@components/cards/ServiceCard.astro';
import ContentGrid from '@components/content/ContentGrid.astro';
import ContactCta from '@components/content/ContactCta.astro';
import NewsletterSignup from '@components/content/NewsletterSignup.astro';
import PageLayout from '@layouts/PageLayout.astro';
import { getHomePageData } from '@lib/queries';

const home = await getHomePageData();
---

<PageLayout
  title="BX컨설팅"
  description="전략, 고객경험, 리서치, 시스템, AI 과제를 실행 중심으로 설계하는 BX컨설팅의 정적 Astro 사이트 초안입니다."
  canonicalPath="/"
  eyebrow="Business eXcellence Consulting"
  heroTitle="경험에서 전략을, 전략에서 성장을 만듭니다."
  heroText="조직과 사업이 실제로 움직일 수 있는 실행 구조를 설계합니다. 이번 1차 구현은 Astro 정적 사이트와 Supabase CMS 구조를 위한 기반 골격입니다."
>
  <Section
    eyebrow="Services"
    title="반복 가능한 구조를 만드는 서비스"
    intro="서비스 상세는 정적 페이지로 구성하고, 홈에서는 주요 영역을 빠르게 탐색할 수 있게 요약합니다."
  >
    <div class="grid-3">
      {home.serviceHighlights.map((item) => <ServiceCard item={item} />)}
    </div>
  </Section>

  <Section
    eyebrow="Portfolio"
    title="실행 결과로 설명하는 프로젝트"
    intro="포트폴리오 상세는 정적 경로로 생성되어 SEO와 공유 미리보기에 유리한 구조를 갖습니다."
  >
    <ContentGrid items={home.featuredPortfolio} variant="portfolio" />
  </Section>

  <Section
    eyebrow="Insight"
    title="리서치와 실무를 연결하는 콘텐츠"
    intro="인사이트, 기획조사, 보도자료는 동일한 공용 템플릿으로 관리되며 CMS 데이터 구조만 다르게 나뉩니다."
  >
    <div class="grid-3">
      <div>
        <h3>인사이트</h3>
        <ContentGrid items={home.featuredInsights} />
      </div>
      <div>
        <h3>기획조사</h3>
        <ContentGrid items={home.featuredReports} />
      </div>
      <div>
        <h3>보도자료</h3>
        <ContentGrid items={home.featuredPress} />
      </div>
    </div>
  </Section>

  <Section
    eyebrow="Next Step"
    title="문의와 구독 흐름도 정적 사이트에 맞게 준비합니다."
    intro="양식 UI는 즉시 확인할 수 있고, 환경변수 연결 시 Supabase Edge Function으로 전송됩니다."
  >
    <div class="grid-2">
      <NewsletterSignup />
      <ContactCta />
    </div>
  </Section>
</PageLayout>
