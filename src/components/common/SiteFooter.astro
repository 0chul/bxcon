---
import { navGroups, siteConfig, withBase } from '@lib/site-config';
---

<footer class="site-footer">
  <div class="container site-footer__grid">
    <div>
      <div class="site-brand">
        <img
          class="site-brand__image site-brand__image--footer"
          src={siteConfig.brandAssets.footerLogo}
          alt={siteConfig.siteNameEn}
          width="212"
          height="30"
        />
      </div>
      <p class="form-note">
        경험에서 전략을, 전략에서 성장을 만듭니다. BX컨설팅은 전략과 현장 실행을 연결하는 파트너입니다.
      </p>
      <div class="footer-contact">
        <span>대표 문의 {siteConfig.contactPhone}</span>
        <a href={`mailto:${siteConfig.contactEmail}`}>{siteConfig.contactEmail}</a>
      </div>
      <p class="form-note">{siteConfig.address}</p>
    </div>

    <div>
      <div class="footer-links">
        {
          navGroups.flatMap((group) => group.links).map((link) => (
            <a href={withBase(link.href)}>{link.label}</a>
          ))
        }
        <a href={withBase('/privacy/')}>개인정보처리방침</a>
      </div>
      <p class="form-note">Fax {siteConfig.contactFax}</p>
    </div>
  </div>
</footer>
