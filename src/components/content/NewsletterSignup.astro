---
const endpoint = import.meta.env.PUBLIC_SUPABASE_URL
  ? `${import.meta.env.PUBLIC_SUPABASE_URL}/functions/v1/subscribe-newsletter`
  : '';
const anonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '';
---

<div class="cta-panel">
  <div>
    <span class="eyebrow">Newsletter</span>
    <h3 style="margin: 0.5rem 0;">주간 인사이트를 이메일로 받아보세요.</h3>
    <p class="form-note">경영, CX, 리서치, AI 관점의 실행 인사이트를 정기적으로 전합니다.</p>
  </div>

  <form class="newsletter-form" data-newsletter-form data-endpoint={endpoint} data-anon-key={anonKey}>
    <div class="form-row">
      <div class="field">
        <label for="newsletter-name">이름</label>
        <input id="newsletter-name" name="name" type="text" placeholder="홍길동" />
      </div>
      <div class="field">
        <label for="newsletter-email">이메일</label>
        <input id="newsletter-email" name="email" type="email" placeholder="you@example.com" required />
      </div>
    </div>
    <p class="form-note">구독 신청 시 개인정보 수집 및 이용에 동의한 것으로 간주합니다.</p>
    <div class="cta-actions">
      <button class="button" type="submit">구독 신청</button>
      <span class="status-message" data-newsletter-status></span>
    </div>
  </form>
</div>

<script is:inline>
  const forms = document.querySelectorAll('[data-newsletter-form]');

  forms.forEach((form) => {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const endpoint = form.getAttribute('data-endpoint');
      const anonKey = form.getAttribute('data-anon-key');
      const statusNode = form.querySelector('[data-newsletter-status]');
      const formData = new FormData(form);
      const payload = {
        name: String(formData.get('name') || '').trim(),
        email: String(formData.get('email') || '').trim(),
      };

      if (!endpoint || !anonKey) {
        statusNode.textContent = '현재는 샘플 모드입니다. 배포 환경변수 연결 후 실제 구독이 활성화됩니다.';
        return;
      }

      statusNode.textContent = '구독을 등록하는 중입니다.';

      try {
        const response = await fetch(endpoint, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            apikey: anonKey,
            Authorization: `Bearer ${anonKey}`,
          },
          body: JSON.stringify(payload),
        });

        if (!response.ok) {
          throw new Error('subscribe failed');
        }

        statusNode.textContent = '구독 신청이 완료되었습니다.';
        form.reset();
      } catch {
        statusNode.textContent = '구독 요청에 실패했습니다. 잠시 후 다시 시도해 주세요.';
      }
    });
  });
</script>
