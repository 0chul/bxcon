---
import type { ArticleDetail, PortfolioDetail } from '@models/content';
import type { BreadcrumbItem } from '@models/site';
import Breadcrumbs from '@components/common/Breadcrumbs.astro';
import { withBase } from '@lib/site-config';

interface Props {
  item: ArticleDetail | PortfolioDetail;
  breadcrumbs: BreadcrumbItem[];
}

const { item, breadcrumbs } = Astro.props;
---

<div class="hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <Breadcrumbs items={breadcrumbs} />
      <span class="eyebrow">{item.kind}</span>
      <h1>{item.title}</h1>
      <p class="article-summary">{item.summary}</p>
      <div class="chip-row" style="margin-top: 1.2rem;">
        {item.tags.map((tag) => <span class="chip">{tag}</span>)}
      </div>
    </div>

    <div class="hero-panel">
      <img src={withBase(item.thumbnail.publicUrl)} alt={item.thumbnail.alt} />
    </div>
  </div>
</div>
