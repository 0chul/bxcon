---
interface Props {
  kind: 'people-first' | 'work-together' | 'smart-simple' | 'think-long' | 'facts-matter' | 'be-real';
  title: string;
}

const { kind, title } = Astro.props;
---

<div class={`core-value-icon core-value-icon--${kind}`} aria-hidden="true" title={title}>
  {
    kind === 'people-first' && (
      <svg viewBox="0 0 96 96" role="img">
        <path d="M28 78h34c6 0 10-4 10-10V53c8-5 12-13 12-24C84 13 69 2 51 2 33 2 18 13 18 29c0 8 3 15 9 20v19c0 6 5 10 11 10Z" />
        <path d="M40 24c3-5 13-5 16 0" />
        <path d="M36 31c0-8 8-14 12-14s12 6 12 14" />
        <path d="M48 17v28" />
        <path d="M40 40c2-4 4-6 8-6s6 2 8 6" />
      </svg>
    )
  }
  {
    kind === 'work-together' && (
      <svg viewBox="0 0 96 96" role="img">
        <rect x="20" y="12" width="56" height="14" rx="7" />
        <circle cx="32" cy="19" r="4" />
        <circle cx="48" cy="19" r="4" />
        <circle cx="64" cy="19" r="4" />
        <circle cx="28" cy="55" r="10" />
        <circle cx="68" cy="55" r="10" />
        <path d="M18 82c2-11 10-17 20-17s18 6 20 17" />
        <path d="M38 82c2-11 10-17 20-17s18 6 20 17" />
        <path d="M38 44 48 32l10 12" />
      </svg>
    )
  }
  {
    kind === 'smart-simple' && (
      <svg viewBox="0 0 96 96" role="img">
        <path d="M18 70h60" />
        <path d="M30 66c4-13 10-22 18-29 7 7 13 16 18 29" />
        <path d="M48 24 18 38l30 14 30-14-30-14Z" />
        <path d="M78 44v22" />
        <path d="M26 73c0 5-4 9-9 9s-9-4-9-9c0-4 3-7 9-13 6 6 9 9 9 13Z" />
      </svg>
    )
  }
  {
    kind === 'think-long' && (
      <svg viewBox="0 0 96 96" role="img">
        <circle cx="48" cy="48" r="19" />
        <circle cx="48" cy="48" r="7" />
        <path d="M48 15v14M48 67v14M15 48h14M67 48h14M26 26l10 10M60 60l10 10M70 26 60 36M26 70l10-10" />
        <circle cx="48" cy="15" r="5" />
        <circle cx="48" cy="81" r="5" />
        <circle cx="15" cy="48" r="5" />
        <circle cx="81" cy="48" r="5" />
      </svg>
    )
  }
  {
    kind === 'facts-matter' && (
      <svg viewBox="0 0 96 96" role="img">
        <circle cx="42" cy="46" r="26" />
        <path d="M42 20v26" />
        <path d="M42 46 61 32" />
        <path d="M42 46 56 68" />
        <circle cx="67" cy="67" r="13" />
        <path d="m76 76 10 10" />
      </svg>
    )
  }
  {
    kind === 'be-real' && (
      <svg viewBox="0 0 96 96" role="img">
        <circle cx="48" cy="48" r="10" />
        <ellipse cx="48" cy="48" rx="28" ry="12" />
        <ellipse cx="48" cy="48" rx="12" ry="28" />
        <path d="M28 20c12 3 22 13 25 28" />
        <path d="M68 20C56 23 46 33 43 48" />
        <path d="M28 76c12-3 22-13 25-28" />
        <path d="M68 76C56 73 46 63 43 48" />
      </svg>
    )
  }
</div>
