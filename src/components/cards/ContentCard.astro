---
import type { ContentListItem } from '@models/content';
import { withBase } from '@lib/site-config';

interface Props {
  item: ContentListItem;
}

const { item } = Astro.props;
---

<article class="content-card">
  <a href={withBase(`/${item.kind}/${item.slug}/`)}>
    <div class="content-card__image">
      <img src={withBase(item.thumbnail.publicUrl)} alt={item.thumbnail.alt} loading="lazy" />
    </div>
    <div class="eyebrow">{item.kind}</div>
    <h3>{item.title}</h3>
    <p>{item.summary}</p>
    <div class="meta-row">
      <span>{item.publishedAt}</span>
      <span>{item.tags.slice(0, 2).join(' · ')}</span>
    </div>
  </a>
</article>
