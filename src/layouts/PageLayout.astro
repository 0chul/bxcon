---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  eyebrow?: string;
  heroTitle?: string;
  heroText?: string;
}

const {
  title,
  description,
  canonicalPath,
  eyebrow,
  heroTitle = title,
  heroText = description,
} = Astro.props;
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath}>
  <section class="hero">
    <div class="container">
      <div class="hero-copy" style="max-width: 760px;">
        {eyebrow && <span class="eyebrow">{eyebrow}</span>}
        <h1>{heroTitle}</h1>
        <p>{heroText}</p>
      </div>
    </div>
  </section>
  <slot />
</BaseLayout>
